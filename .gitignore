# Local camera captures and generated image artifacts. Keep only the usage
# documentation so a fresh clone contains the directory but never its images.
/photos/**
!/photos/README.md

# Arduino/ESP32 build output.
.build/

# Local camera application output.
pi_app/captures/

# Canonical UX concepts live under designs/ux-mockups. Keep duplicate working
# copies and closed-checkpoint exploratory logs local unless explicitly promoted
# to qualifying evidence.
assets/ux-mockups/
docs/evidence/milestone-1/checkpoint-5/*.log

# Python environments, bytecode, and tool caches.
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Operating-system metadata.
.DS_Store
Thumbs.db
Desktop.ini
.maintenance-backups/
